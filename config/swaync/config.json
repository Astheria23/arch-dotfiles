{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-width": 350,
  "control-center-margin-top": 10,
  "control-center-margin-bottom": 10,
  "control-center-margin-right": 10,
  "control-center-margin-left": 10,
  "notification-window-width": 350,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-length": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "widgets": [
    "title",
    "buttons-grid#toggles",
    "label#battery",
    "label#network",
    "mpris",
    "volume",
    "buttons-grid#audio",
    "backlight",
    "notifications",
    "buttons-grid#power"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "buttons-grid#toggles": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "󰂚",
          "command": "swaync-client -d",
          "type": "toggle",
          "update-command": "swaync-client -D | grep -q 'true' && echo true || echo false"
        },
        {
          "label": "󰂯",
          "command": "~/.config/waybar/scripts/bluetooth_toggle.sh",
          "type": "toggle",
          "update-command": "bluetoothctl show 2>/dev/null | grep -q 'Powered: yes' && echo true || echo false"
        },
        {
          "label": "󰤨",
          "command": "~/.config/waybar/scripts/wifi_toggle.sh",
          "type": "toggle",
          "update-command": "nmcli radio wifi 2>/dev/null | grep -q 'enabled' && echo true || echo false"
        },
        {
          "label": "󰝟",
          "command": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
          "type": "toggle",
          "update-command": "wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED && echo true || echo false"
        }
      ]
    },
    "label#battery": {
      "text": "󰁺  100%"
    },
    "label#network": {
      "text": "󰤨  OGEZ FAMILY"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "show-per-app-icon": true,
      "show-per-app-label": true,
      "expand-per-app": true
    },
    "buttons-grid#audio": {
      "buttons-per-row": 1,
      "actions": [
        {
          "label": "󰋋  Switch Output",
          "command": "~/.config/waybar/scripts/audio_switcher.sh"
        }
      ]
    },
    "backlight": {
      "label": "󰖙",
      "device": "amdgpu_bl1"
    },
    "notifications": {},
    "buttons-grid#power": {
      "buttons-per-row": 3,
      "actions": [
        {
          "label": "󰜉\nReboot",
          "command": "zenity --question --title='Reboot' --text='Are you sure you want to reboot?' --ok-label='Reboot' --cancel-label='Cancel' && systemctl reboot"
        },
        {
          "label": "󰍃\nLogout",
          "command": "zenity --question --title='Logout' --text='Are you sure you want to logout?' --ok-label='Logout' --cancel-label='Cancel' && hyprctl dispatch exit"
        },
        {
          "label": "󰐥\nShutdown",
          "command": "zenity --question --title='Shutdown' --text='Are you sure you want to shutdown?' --ok-label='Shutdown' --cancel-label='Cancel' && systemctl poweroff"
        }
      ]
    }
  }
}